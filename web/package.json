{
  "name": "conky-website",
  "description": "Conky website",
  "author": "Conky developers",
  "license": "GPL-3.0-only",
  "contributors": [
    "Brenden Matthews"
  ],
  "homepage": "https://github.com/brndnmtthws/conky",
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": "1.3.10"
  },
  "bugs": {
    "url": "https://github.com/brndnmtthws/conky/issues"
  },
  "scripts": {
    "dev": "bun run write-search-index && next dev",
    "dev:watch": "bun run write-search-index && next-remote-watch ./documents",
    "build": "bun run write-search-index && next build",
    "start": "next start",
    "lint": "eslint .",
    "e2e": "start-server-and-test \"bun run dev\" http://localhost:3000 \"cypress open --e2e\"",
    "e2e:headless": "start-server-and-test \"bun run dev\" http://localhost:3000 \"cypress run --e2e\"",
    "write-search-index": "tsx ./scripts/write-search-index.ts"
  },
  "dependencies": {
    "@fontsource-variable/fira-code": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@headlessui/react": "^2.2.9",
    "@tailwindcss/typography": "^0.5.19",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.542.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-parse": "^9.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.1.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.4.27",
    "baseline-browser-mapping": "^2.10.0",
    "cypress": "^15.11.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.4.0",
    "js-yaml": "^4.1.1",
    "next-remote-watch": "2.0.0",
    "postcss": "^8.5.8",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
