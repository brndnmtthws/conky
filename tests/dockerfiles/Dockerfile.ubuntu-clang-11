ARG IMAGE=registry.gitlab.com/brndnmtthws-oss/conky
FROM ${IMAGE}/builder/ubuntu-base:latest

ARG BUN_VERSION=1.3.14
ARG BUN_LINUX_X64_SHA256=951ee2aee855f08595aeec6225226a298d3fea83a3dcd6465c09cbccdf7e848f
ENV BUN_INSTALL=/root/.bun
ENV PATH="${BUN_INSTALL}/bin:${PATH}"

RUN wget -q https://apt.llvm.org/llvm-snapshot.gpg.key \
  && apt-key add llvm-snapshot.gpg.key \
  && add-apt-repository 'deb http://apt.llvm.org/focal/ llvm-toolchain-focal-11 main' \
  && DEBIAN_FRONTEND=noninteractive \
  apt-get install -qy --no-install-recommends \
  clang-11 \
  clang-format-11 \
  clang-tidy-11 \
  clang-tools-11 \
  curl \
  gcovr \
  libc++-11-dev \
  libc++abi-11-dev \
  lld-11 \
  lldb-11 \
  llvm-11 \
  unzip \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/* \
  && curl -fsSLo /tmp/bun.zip "https://github.com/oven-sh/bun/releases/download/bun-v${BUN_VERSION}/bun-linux-x64.zip" \
  && echo "${BUN_LINUX_X64_SHA256}  /tmp/bun.zip" | sha256sum -c - \
  && unzip -q /tmp/bun.zip -d /tmp \
  && mkdir -p "${BUN_INSTALL}/bin" \
  && mv /tmp/bun-linux-x64/bun "${BUN_INSTALL}/bin/bun" \
  && rm -rf /tmp/bun.zip /tmp/bun-linux-x64 \
  && bun add --global lcov-summary
